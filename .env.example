# FinGenius AI - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional model overrides (defaults shown)
# FINGENIUS_CHAT_MODEL=gpt-4o-mini
# FINGENIUS_EMBEDDING_MODEL=text-embedding-3-small
# FINGENIUS_TEMPERATURE=0.2

# Where the local Chroma vector store is persisted
# FINGENIUS_CHROMA_DIR=.chroma
